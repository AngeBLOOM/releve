NODE_ENV=production
PORT=3001

# PostgreSQL (Neon u otro). Ej: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=

# Redis (Upstash u otro). Ej: redis://default:pass@host:port  (o rediss:// con TLS)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Meta (WhatsApp / Instagram / Messenger)
META_APP_SECRET=
META_VERIFY_TOKEN=sublicolor_webhook_2024
META_APP_ID=

WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_PAGE_ID=

MESSENGER_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# OpenAI (respuestas naturales del bot)
OPENAI_API_KEY=

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=8h

# URLs públicas (dominios del deploy)
WEB_URL=
STORE_PUBLIC_URL=
WEBHOOK_CALLBACK_URL=

# Cloudinary (subida de diseños)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
